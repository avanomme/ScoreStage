{
  "rules": {
    "max_files_per_patch": 3,
    "max_lines_per_patch": 200,
    "prefer_small_prs": true,
    "require_acceptance_criteria": true,
    "auto_update_tasks": true,
    "auto_update_decisions": true
  },
  "permissions": {
    "filesystem": true,
    "web_access": false,
    "execution": false
  }
}
